+
+    if (renderNodePath.isEmpty()) {
+        return nullptr;
+    }
+
+    auto renderDevice = RenderDevice::open(renderNodePath);
+    if (!renderDevice) {
+        return nullptr;
+    }
+    qCDebug(KWIN_CORE, "Opened render device %s", qPrintable(renderDevice->drmDevice()->path()));
+    auto shared = std::shared_ptr<RenderDevice>(std::move(renderDevice));
+    m_openDevices.push_back(shared);
