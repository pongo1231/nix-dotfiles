+/// Set up epoll-based event loop: timer for periodic ticks, signalfd for signals
+static bool init_event_loop(int *efd_out, int *tfd_out, int *sfd_out)
+{
+  int efd = epoll_create1(EPOLL_CLOEXEC);
+  if (unlikely(efd == -1))
+  {
+    log_perr(LOG_ERR, "epoll_create1", errno);
+    return false;
+  }
+
+  int tfd = timerfd_create(CLOCK_MONOTONIC, TFD_CLOEXEC);
+  if (unlikely(tfd == -1))
+  {
+    log_perr(LOG_ERR, "timerfd_create", errno);
+    close(efd);
+    return false;
+  }
+  struct itimerspec its = {
+    .it_interval = { .tv_sec = 1, .tv_nsec = 0 },
+    .it_value    = { .tv_sec = 1, .tv_nsec = 0 }
+  };
+  timerfd_settime(tfd, 0, &its, NULL);
+
+  struct epoll_event ev = { .events = EPOLLIN };
+
+  ev.data.fd = tfd;
+  if (unlikely(epoll_ctl(efd, EPOLL_CTL_ADD, tfd, &ev) == -1))
+  {
+    log_perr(LOG_ERR, "epoll_ctl(timerfd)", errno);
+    close(tfd); close(efd);
+    return false;
+  }
+
+  sigset_t mask;
+  sigemptyset(&mask);
+  sigaddset(&mask, SIGTERM);
+  sigaddset(&mask, SIGHUP);
+  sigaddset(&mask, SIGUSR1);
+  sigaddset(&mask, SIGUSR2);
+#ifdef SIGPWR
+  sigaddset(&mask, SIGPWR);
+#endif
+
+  // Ignore SIGXFSZ (file size limit) — we handle EFBIG ourselves
+#ifdef SIGXFSZ
+  signal(SIGXFSZ, SIG_IGN);
+#endif
+
+  if (unlikely(sigprocmask(SIG_BLOCK, &mask, NULL) == -1))
+  {
+    log_perr(LOG_ERR, "sigprocmask", errno);
+    close(tfd); close(efd);
+    return false;
+  }
+
+  int sfd = signalfd(-1, &mask, SFD_CLOEXEC);
+  if (unlikely(sfd == -1))
+  {
+    log_perr(LOG_ERR, "signalfd", errno);
+    close(tfd); close(efd);
+    return false;
+  }
+
+  ev.data.fd = sfd;
+  if (unlikely(epoll_ctl(efd, EPOLL_CTL_ADD, sfd, &ev) == -1))
+  {
+    log_perr(LOG_ERR, "epoll_ctl(signalfd)", errno);
+    close(sfd); close(tfd); close(efd);
+    return false;
+  }
+
+  *efd_out = efd;
+  *tfd_out = tfd;
+  *sfd_out = sfd;
+  return true;
+}
