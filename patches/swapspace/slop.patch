+/// Sync file data to disk before calling swapon
+static void sync_swapfile(int fd, off_t size)
+{
+  sync_file_range(fd, 0, size,
+      SYNC_FILE_RANGE_WAIT_BEFORE |
+      SYNC_FILE_RANGE_WRITE |
+      SYNC_FILE_RANGE_WAIT_AFTER);
+  fdatasync(fd);
+}
