+// ---- Swap header writing (replaces external mkswap) ----
+
+#define SWAP_MAGIC "SWAPSPACE2"
+#define SWAP_MAGIC_SZ (sizeof(SWAP_MAGIC) - 1)
+#define SWAP_BOOTBITS_SZ 1024
+
+/// Write a valid swap header to the file descriptor
+/// The file must already be filled with data (zero or otherwise).
+/// The first page is overwritten with the swap header.
+static bool write_swap_header(int fd, off_t size_bytes)
+{
+  const long pagesize = getpagesize();
+  const uint32_t npages = (uint32_t)(size_bytes / pagesize);
+
+  assert(sizeof(localbuf) >= (size_t)pagesize);
+
+  memset(localbuf, 0, pagesize);
+
+  uint32_t v;
+  // version = 1 at offset 1024
+  v = 1;
+  memcpy(localbuf + SWAP_BOOTBITS_SZ, &v, sizeof(v));
+  // last_page = npages - 1 at offset 1028
+  v = npages - 1;
+  memcpy(localbuf + SWAP_BOOTBITS_SZ + 4, &v, sizeof(v));
+  // nr_badpages at offset 1032 is already 0 (from memset)
+  // uuid at offset 1036 is already 0
+  // volume_name at offset 1052 is already 0
+
+  // Magic string at end of page
+  memcpy(localbuf + pagesize - SWAP_MAGIC_SZ, SWAP_MAGIC, SWAP_MAGIC_SZ);
+
+  return (pwrite(fd, localbuf, pagesize, 0) == pagesize);
+}
