+/// Turn an existing file into an active swap.  Clobbers localbuf.
+/**
+ * @return Whether file was activated successfully.
+ */
+static bool enable_swapfile(const char file[])
+{
+  int fd = open(file, O_RDWR | O_LARGEFILE);
+  if (unlikely(fd == -1))
+  {
+    log_perr_str(LOG_ERR, "Could not open swapfile for header write", file, errno);
+    return false;
+  }
+
+  off_t size = SEEK(fd, 0, SEEK_END);
+  if (unlikely(size == -1))
+  {
+    log_perr_str(LOG_ERR, "Could not determine swapfile size", file, errno);
+    close(fd);
+    return false;
+  }
+
+  if (unlikely(!write_swap_header(fd, size)))
+  {
+    log_perr_str(LOG_ERR, "Could not write swap header to", file, errno);
+    close(fd);
+    return false;
+  }
+
+  sync_swapfile(fd, size);
+
+  check_swap_extents(fd);  // may disable fast allocation, but we still try swapon
+
+#ifdef HAVE_SELINUX
+  if (is_selinux_enabled())
+    setfilecon(file, "swapfile_t");
+#endif
+
+  close(fd);
+
+  const bool ok = (swapon(file, 0) == 0);
+  if (unlikely(!ok))
+  {
+    if (errno == EINVAL)
+    {
+      pfalloc_ok = false;
+      logm(LOG_NOTICE, "Quick swapfile creation disabled.");
+    }
+    log_perr_str(LOG_ERR, "Could not enable swapfile", file, errno);
+  }
+  return ok;
+}
