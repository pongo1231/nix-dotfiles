+int dbfile_prune_unscanned_files(struct dbhandle *db)
+{
+	int ret;
+	uint64_t ino, subvol;
+	_cleanup_(sqlite3_reset_stmt) sqlite3_stmt *select = db->stmts.get_unscanned_files;
+	_cleanup_(sqlite3_reset_stmt) sqlite3_stmt *delete = db->stmts.delete_file_from_ino;
+
+	while ((ret = sqlite3_step(select)) == SQLITE_ROW) {
+		ino = sqlite3_column_int64(select, 0);
+		subvol = sqlite3_column_int64(select, 1);
+
+		ret = sqlite3_bind_int64(delete, 1, ino);
+		if (ret) {
+			perror_sqlite(ret, "binding");
+			return ret;
+		}
+
+		ret = sqlite3_bind_int64(delete, 2, subvol);
+		if (ret) {
+			perror_sqlite(ret, "binding");
+			return ret;
+		}
+
+		ret = sqlite3_step(delete);
+		if(ret != SQLITE_DONE) {
+			perror_sqlite(ret, "executing sql");
+			return ret;
+		}
+		sqlite3_reset(delete);
+	}
+
+	if (ret != SQLITE_DONE) {
+		perror_sqlite(ret, "retrieving unscanned files");
+		return ret;
+	}
+
+	return 0;
+}
