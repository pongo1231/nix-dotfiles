+MU_TEST(test_results_tree_score) {
+	struct results_tree res;
+	struct dupe_extents *dext;
+	struct extent *extent;
+	struct filerec file1 = { 0, };
+	struct filerec file2 = { 0, };
+	struct filerec file3 = { 0, };
+	unsigned char digest[DIGEST_LEN] = { 1, };
+	uint64_t len = 4096;
+
+	init_results_tree(&res);
+
+	mu_check(insert_one_result(&res, digest, &file1, 0, len, 0) == 0);
+	dext = rb_entry(rb_first(&res.root), struct dupe_extents, de_node);
+	mu_check(dext->de_num_dupes == 1);
+	mu_check(dext->de_score == 0);
+
+	mu_check(insert_one_result(&res, digest, &file2, 0, len, 0) == 0);
+	mu_check(dext->de_num_dupes == 2);
+	mu_check(dext->de_score == len);
+
+	mu_check(insert_one_result(&res, digest, &file3, 0, len, 0) == 0);
+	mu_check(dext->de_num_dupes == 3);
+	mu_check(dext->de_score == len * 2);
+
+	extent = list_entry(dext->de_extents.next, struct extent, e_list);
+	mu_check(remove_extent(&res, extent) == 2);
+	mu_check(dext->de_score == len);
+
+	free_results_tree(&res);
+}
+
+MU_TEST(test_partial_search_pair_ordering) {
+	struct filerec file1 = { .fileid = 1 };
+	struct filerec file2 = { .fileid = 2 };
+	struct file_block a = { .b_file = &file1, .b_loff = 0 };
+	struct file_block b = { .b_file = &file2, .b_loff = 0 };
+	struct file_block c = { .b_file = &file1, .b_loff = 4096 };
+
+	mu_check(should_search_block_pair(&a, &b) == true);
+	mu_check(should_search_block_pair(&b, &a) == false);
+	mu_check(should_search_block_pair(&a, &c) == true);
+	mu_check(should_search_block_pair(&c, &a) == false);
+	mu_check(should_search_block_pair(&a, &a) == false);
+}
+
+MU_TEST(test_partial_search_len_caps) {
+	struct filerec file1 = { .fileid = 1 };
+	struct filerec file2 = { .fileid = 2 };
+	struct file_block block = { .b_file = &file1, .b_loff = 100 };
+	struct file_block found = { .b_file = &file2, .b_loff = 150 };
+	struct file_extent extent = { .loff = 128, .len = 512 };
+
+	mu_check(extent_remaining_from_block(&extent, &found) == 490);
+	found.b_loff = 127;
+	mu_check(extent_remaining_from_block(&extent, &found) == 0);
+	found.b_loff = 640;
+	mu_check(extent_remaining_from_block(&extent, &found) == 0);
+
+	block.b_file = &file1;
+	block.b_loff = 0;
+	found.b_file = &file1;
+	found.b_loff = 8192;
+	mu_check(cap_same_file_search_len(&block, &found, 16384) == 8192);
+	mu_check(cap_same_file_search_len(&found, &block, 16384) == 0);
+
+	found.b_file = &file2;
+	mu_check(cap_same_file_search_len(&block, &found, 16384) == 16384);
+}
