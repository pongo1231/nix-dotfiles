+int filerec_find_cached_extent(struct filerec *file, uint64_t loff,
+			       uint64_t *extent_loff, uint64_t *poff,
+			       uint64_t *len)
+{
+	int lo, hi;
+
+	if (!file->extent_cache_loaded || !file->extent_cache)
+		return -1;
+
+	lo = 0;
+	hi = (int)file->num_extent_cache - 1;
+
+	while (lo <= hi) {
+		int mid = (lo + hi) / 2;
+		struct file_extent *e = &file->extent_cache[mid];
+
+		if (loff < e->loff)
+			hi = mid - 1;
+		else if (loff >= e->loff + e->len)
+			lo = mid + 1;
+		else {
+			if (extent_loff)
+				*extent_loff = e->loff;
+			if (poff)
+				*poff = e->poff;
+			if (len)
+				*len = e->len;
+			return 0;
+		}
+	}
+	return -1;
+}
