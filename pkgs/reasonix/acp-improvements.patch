+	modes := make([]SessionMode, 0, len(modelRefs))
+	for _, ref := range modelRefs {
+		modes = append(modes, SessionMode{
+			ID:          ref,
+			Name:        ref,
+			Description: "Switch model to " + ref,
+		})
+	}
+	if len(modes) == 0 {
+		modes = []SessionMode{{ID: "code", Name: "Code", Description: "Full filesystem access + code tools"}}
+	}
+
+	currentID := "code"
+	if sess := s.session(p.SessionID); sess != nil {
+		currentID = sess.ctrl.Label()
+	}
+	return SetModeResult{
+		Modes: SessionModeState{
+			CurrentModeID:  currentID,
+			AvailableModes: modes,
+		},
+	}, nil
