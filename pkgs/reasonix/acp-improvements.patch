+func (s *service) configSet(_ context.Context, raw json.RawMessage) (any, error) {
+	var p SetConfigOptionParams
+	if err := json.Unmarshal(raw, &p); err != nil {
+		return nil, &RPCError{Code: ErrInvalidParams, Message: "config/set: " + err.Error()}
+	}
+	sess := s.session(p.SessionID)
+	if sess == nil {
+		return nil, &RPCError{Code: ErrInvalidParams, Message: "config/set: unknown session " + p.SessionID}
+	}
