+		if p.Value == "" {
+			break
+		}
+		// Don't rebuild when already on this model.
+		curLabel := sess.ctrl.Label()
+		if curLabel == p.Value {
+			break
+		}
+		history := sess.ctrl.History()
+		// Persist and close the old controller.
+		_ = sess.ctrl.Snapshot()
+		sess.ctrl.Close()
