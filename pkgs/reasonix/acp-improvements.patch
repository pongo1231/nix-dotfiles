+// ── Tool title builder ──────────────────────────────────────────────────────
+// Produces a human-readable one-liner from tool name + parsed args so ACP
+// clients (Zed, etc.) show WHAT the tool is doing, not just its name.
+
+const MAX_TITLE_ARG = 80;
+
+function ellipsis(s: string, max: number): string {
+  if (s.length <= max) return s;
+  return `${s.slice(0, max)}…`;
+}
+
+/** Human-readable label when we don't have args yet (tool.preparing). */
+function toolNameLabel(name: string): string {
+  switch (name) {
+    case "run_command": return "Run command";
+    case "run_background": return "Background command";
+    case "job_output": return "Job output";
+    case "wait_for_job": return "Wait for job";
+    case "stop_job": return "Stop job";
+    case "list_jobs": return "List jobs";
+    case "read_file": return "Read file";
+    case "list_directory": return "List directory";
+    case "directory_tree": return "Directory tree";
+    case "search_files": return "Find files";
+    case "search_content": return "Search code";
+    case "glob": return "Glob";
+    case "get_file_info": return "Stat file";
+    case "get_symbols": return "Symbols";
+    case "find_in_code": return "Find in file";
+    case "write_file": return "Write file";
+    case "edit_file": return "Edit file";
+    case "multi_edit": return "Multi-edit";
+    case "delete_range": return "Delete range";
+    case "delete_symbol": return "Delete symbol";
+    case "create_directory": return "Create directory";
+    case "move_file": return "Move file";
+    case "delete_file": return "Delete file";
+    case "delete_directory": return "Delete directory";
+    case "copy_file": return "Copy file";
+    case "web_search": return "Web search";
+    case "web_fetch": return "Web fetch";
+    case "submit_plan": return "Submit plan";
+    case "mark_step_complete": return "Mark step complete";
+    case "revise_plan": return "Revise plan";
+    case "todo_write": return "Todo";
+    case "remember": return "Remember";
+    case "forget": return "Forget";
+    case "recall_memory": return "Recall memory";
+    case "run_skill": return "Run skill";
+    case "install_skill": return "Install skill";
+    case "create_skill": return "Create skill";
+    case "explore": return "Explore";
+    case "research": return "Research";
+    case "review": return "Review";
+    case "security_review": return "Security review";
+    case "ask_choice": return "Ask";
+    case "add_mcp_server": return "Add MCP server";
+    default: return name;
+  }
+}
+
+function toolTitle(name: string, parsed: unknown): string {
+  const args = parsed && typeof parsed === "object" && !Array.isArray(parsed)
+    ? parsed as Record<string, unknown>
+    : null;
+
+  switch (name) {
+    // ── Shell ──────────────────────────────────────────────────────────
+    case "run_command":
+      return cmd("Run", args);
+    case "run_background":
+      return cmd("Background", args);
+    case "job_output":
+      return `Job output #${args?.jobId ?? "?"}`;
+    case "wait_for_job":
+      return `Wait job #${args?.jobId ?? "?"}`;
+    case "stop_job":
+      return `Stop job #${args?.jobId ?? "?"}`;
+    case "list_jobs":
+      return "List jobs";
+
+    // ── File reads ─────────────────────────────────────────────────────
+    case "read_file":
+      return path("Read", args);
+    case "list_directory":
+      return path("List", args);
+    case "directory_tree":
+      return path("Tree", args);
+    case "search_files":
+      return pattern("Find files", args);
+    case "search_content":
+      return pattern("Search", args);
+    case "glob":
+      return pattern("Glob", args);
+    case "get_file_info":
+      return path("Stat", args);
+    case "get_symbols":
+      return path("Symbols", args);
+    case "find_in_code":
+      return `Find \`${args?.name ?? "?"}\``;
+    case "java_source":
+      return `Java source: ${args?.className ?? "?"}`;
+
+    // ── File writes / mutations ────────────────────────────────────────
+    case "write_file":
+      return path("Write", args);
+    case "edit_file":
+      return path("Edit", args);
+    case "multi_edit": {
+      const edits = Array.isArray(args?.edits) ? args!.edits.length : 0;
+      return edits ? `Multi-edit: ${edits} file${edits === 1 ? "" : "s"}` : "Multi-edit";
+    }
+    case "delete_range":
+      return path("Delete range", args);
+    case "delete_symbol":
+      return `Delete \`${args?.name ?? "?"}\``;
+    case "create_directory":
+      return path("Mkdir", args);
+    case "move_file":
+      return twoPath("Move", args);
+    case "delete_file":
+      return path("Delete", args);
+    case "delete_directory":
+      return path("Rmdir", args);
+    case "copy_file":
+      return twoPath("Copy", args);
+
+    // ── Web ────────────────────────────────────────────────────────────
+    case "web_search":
+      return query("Web", args);
+    case "web_fetch":
+      return url("Fetch", args);
+
+    // ── Planning / tasks ───────────────────────────────────────────────
+    case "submit_plan":
+      return `Plan: ${ellipsis(String(args?.summary ?? args?.plan ?? ""), MAX_TITLE_ARG) || "Submit plan"}`;
+    case "mark_step_complete":
+      return `Step done: ${args?.stepId ?? "?"}`;
+    case "revise_plan":
+      return "Revise plan";
+    case "todo_write": {
+      const todos = Array.isArray(args?.todos) ? args!.todos.length : 0;
+      return todos ? `Todo: ${todos} item${todos === 1 ? "" : "s"}` : "Todo";
+    }
+
+    // ── Memory ─────────────────────────────────────────────────────────
+    case "remember":
+      return `Remember: ${args?.name ?? "?"}`;
+    case "forget":
+      return `Forget: ${args?.name ?? "?"}`;
+    case "recall_memory":
+      return `Recall: ${args?.name ?? "?"}`;
+
+    // ── Skills / subagents ─────────────────────────────────────────────
+    case "run_skill":
+      return `Skill: ${args?.name ?? "?"}`;
+    case "install_skill":
+      return `Install skill: ${args?.name ?? "?"}`;
+    case "create_skill":
+      return `Create skill: ${args?.name ?? "?"}`;
+    case "explore":
+      return `Explore: ${ellipsis(String(args?.task ?? ""), MAX_TITLE_ARG) || "exploring"}`;
+    case "research":
+      return `Research: ${ellipsis(String(args?.task ?? ""), MAX_TITLE_ARG) || "researching"}`;
+    case "review":
+      return `Review: ${ellipsis(String(args?.task ?? ""), MAX_TITLE_ARG) || "reviewing"}`;
+    case "security_review":
+      return `Security: ${ellipsis(String(args?.task ?? ""), MAX_TITLE_ARG) || "reviewing"}`;
+
+    // ── Other ──────────────────────────────────────────────────────────
+    case "ask_choice":
+      return `Ask: ${ellipsis(String(args?.question ?? ""), MAX_TITLE_ARG) || "choose"}`;
+    case "add_mcp_server":
+      return `Add MCP: ${args?.name ?? "?"}`;
+
+    default:
+      return name;
+  }
+}
+
+function cmd(verb: string, args: Record<string, unknown> | null): string {
+  const c = typeof args?.command === "string" ? args!.command.trim() : "";
+  if (!c) return `${verb} command`;
+  const firstLine = c.split("\n")[0] ?? c;
+  return `${verb}: ${ellipsis(firstLine, MAX_TITLE_ARG)}`;
+}
+
+function path(verb: string, args: Record<string, unknown> | null): string {
+  const p = typeof args?.path === "string" ? args!.path.trim() : "";
+  if (!p) return verb;
+  return `${verb}: ${ellipsis(p, MAX_TITLE_ARG)}`;
+}
+
+function twoPath(verb: string, args: Record<string, unknown> | null): string {
+  const src = typeof args?.source === "string" ? args!.source.trim() : "";
+  const dst = typeof args?.destination === "string" ? args!.destination.trim() : "";
+  if (!src && !dst) return verb;
+  const srcShort = ellipsis(src, 35);
+  const dstShort = ellipsis(dst, 35);
+  return dst ? `${verb}: ${srcShort} → ${dstShort}` : `${verb}: ${srcShort}`;
+}
+
+function pattern(verb: string, args: Record<string, unknown> | null): string {
+  const p = typeof args?.pattern === "string" ? args!.pattern.trim() : "";
+  if (!p) return verb;
+  return `${verb}: \`${ellipsis(p, MAX_TITLE_ARG - 2)}\``;
+}
+
+function query(verb: string, args: Record<string, unknown> | null): string {
+  const q = typeof args?.query === "string" ? args!.query.trim() : "";
+  if (!q) return verb;
+  return `${verb}: ${ellipsis(q, MAX_TITLE_ARG)}`;
+}
+
+function url(verb: string, args: Record<string, unknown> | null): string {
+  const u = typeof args?.url === "string" ? args!.url.trim() : "";
+  if (!u) return verb;
+  return `${verb}: ${ellipsis(u, MAX_TITLE_ARG)}`;
+}
