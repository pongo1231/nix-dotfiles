+
+// ── Plan dispatch ──────────────────────────────────────────────────────────
+
+export function dispatchPlanSubmitted(
+  server: AcpServer,
+  sessionId: string,
+  body: string,
+  steps: ReadonlyArray<{ id: string; title: string; action: string }>,
+): void {
+  emit(server, {
+    sessionId,
+    update: {
+      sessionUpdate: "plan",
+      entries: steps.map((s) => ({
+        content: `${s.title}: ${s.action}`,
+        priority: "medium" as const,
+        status: "pending" as const,
+      })),
+    },
+  });
+}
+
+export function dispatchPlanStepCompleted(
+  server: AcpServer,
+  sessionId: string,
+  stepId: string,
+  title: string | undefined,
+): void {
+  emit(server, {
+    sessionId,
+    update: {
+      sessionUpdate: "plan",
+      entries: [
+        {
+          content: title ?? stepId,
+          priority: "medium" as const,
+          status: "completed" as const,
+        },
+      ],
+    },
+  });
+}
+
+// ── Session metadata dispatch ──────────────────────────────────────────────
+
+export function dispatchSessionInfoUpdate(
+  server: AcpServer,
+  sessionId: string,
+  opts: { title?: string; updatedAt?: string },
+): void {
+  emit(server, {
+    sessionId,
+    update: {
+      sessionUpdate: "session_info_update",
+      title: opts.title ?? null,
+      updatedAt: opts.updatedAt ?? null,
+    },
+  });
+}
+
+// ── Usage dispatch ─────────────────────────────────────────────────────────
+
+export function dispatchUsageUpdate(
+  server: AcpServer,
+  sessionId: string,
+  opts: { promptTokens: number; completionTokens: number; totalTokens: number; costUsd: number },
+): void {
+  emit(server, {
+    sessionId,
+    update: {
+      sessionUpdate: "usage_update",
+      used: opts.totalTokens,
+      size: opts.promptTokens + opts.completionTokens,
+      cost: { amount: opts.costUsd, currency: "USD" },
+    },
+  });
+}
+
+// ── Available commands dispatch ────────────────────────────────────────────
+
+const ACP_SLASH_COMMANDS = [
+  { name: "help", description: "Show available commands" },
+  { name: "clear", description: "Clear the conversation history" },
+  { name: "compact", description: "Compact conversation to save context" },
+  { name: "diff", description: "Show pending changes as a diff" },
+  { name: "undo", description: "Undo the last file operation" },
+  { name: "model", description: "Show or change the current model" },
+  { name: "mode", description: "Show or change the edit mode" },
+  { name: "plan", description: "Show current plan status" },
+  { name: "mcp", description: "Manage MCP servers" },
+];
+
+export function dispatchAvailableCommands(server: AcpServer, sessionId: string): void {
+  emit(server, {
+    sessionId,
+    update: {
+      sessionUpdate: "available_commands_update",
+      available_commands: ACP_SLASH_COMMANDS,
+    },
+  });
+}
