+			{Name: "clear", Description: "Clear the conversation history"},
+			{Name: "compact", Description: "Compact conversation to save context"},
+			{Name: "diff", Description: "Show pending changes as a diff"},
+			{Name: "undo", Description: "Undo the last file operation"},
+			{Name: "model", Description: "Show or change the current model"},
+			{Name: "mode", Description: "Show or change the edit mode"},
+			{Name: "plan", Description: "Show current plan status"},
