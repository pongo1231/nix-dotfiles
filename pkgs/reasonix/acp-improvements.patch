+// DispatchPlanSubmitted sends a plan update with all steps as pending. Called
+// when the agent submits a plan (e.g., after submit_plan in plan mode).
+func (s *updateSink) DispatchPlanSubmitted(steps []PlanStep) {
+	entries := make([]planEntry, 0, len(steps))
+	for _, st := range steps {
+		entries = append(entries, planEntry{
+			Content:  st.Title + ": " + st.Action,
+			Priority: "medium",
+			Status:   "pending",
+		})
+	}
+	if len(entries) > 0 {
+		s.send(planUpdate{SessionUpdate: "plan", Entries: entries})
+	}
+}
+
+// PlanStep is a single step in a plan, as dispatched to ACP clients.
+type PlanStep struct {
+	Title  string
+	Action string
+}
+
+// DispatchPlanStepCompleted sends a plan update marking one step as completed.
+func (s *updateSink) DispatchPlanStepCompleted(stepID, title string) {
+	content := title
+	if content == "" {
+		content = stepID
+	}
+	s.send(planUpdate{
+		SessionUpdate: "plan",
+		Entries:       []planEntry{{Content: content, Priority: "medium", Status: "completed"}},
+	})
+}
+
+// DispatchUsageUpdate sends token usage + cost to the client. Call after each
