+// maxTitleArg is the max width for a tool argument embedded in the title.
+const maxTitleArg = 80
+
+// toolTitle builds a human-readable one-liner from tool name + JSON args so ACP
+// clients (Zed, etc.) show WHAT the tool is doing, not just its raw name.
+// Ported from main's src/acp/dispatch.ts toolTitle / toolNameLabel.
+func toolTitle(name string, args json.RawMessage) string {
+	if len(args) == 0 || !json.Valid(args) {
+		return toolNameLabel(name)
+	}
+	var p map[string]any
+	if json.Unmarshal(args, &p) != nil {
+		return toolNameLabel(name)
+	}
+
+	switch name {
+	// Shell
+	case "bash":
+		return cmdTitle("Run", p)
+	case "bash_output":
+		return fmt.Sprintf("Job output: %v", p["job_id"])
+	case "kill_shell":
+		return fmt.Sprintf("Stop job: %v", p["job_id"])
+	case "wait":
+		return "Wait for jobs"
+
+	// File reads
+	case "read_file":
+		return pathTitle("Read", p)
+	case "ls":
+		return pathTitle("List", p)
+	case "glob":
+		return patternTitle("Glob", p)
+	case "grep":
+		return patternTitle("Search", p)
+	case "web_fetch":
+		return urlTitle("Fetch", p)
+
+	// File writes / mutations
+	case "write_file":
+		return pathTitle("Write", p)
+	case "edit_file":
+		return pathTitle("Edit", p)
+	case "multi_edit":
+		edits, _ := p["edits"].([]any)
+		n := len(edits)
+		if n > 0 {
+			return fmt.Sprintf("Multi-edit: %d file%s", n, plural(n))
+		}
+		return "Multi-edit"
+
+	// Planning
+	case "complete_step":
+		return fmt.Sprintf("Step done: %v", p["step"])
+
+	// Subagent / task
+	case "task":
+		return taskTitle("Task", p)
+
+	default:
+		return name
+	}
+}
+
+// toolNameLabel is a human-readable label when we don't have args yet (tool.pending).
+func toolNameLabel(name string) string {
+	switch name {
+	case "bash":
+		return "Run command"
+	case "bash_output":
+		return "Job output"
+	case "kill_shell":
+		return "Stop job"
+	case "wait":
+		return "Wait for jobs"
+	case "read_file":
+		return "Read file"
+	case "ls":
+		return "List directory"
+	case "glob":
+		return "Glob"
+	case "grep":
+		return "Search code"
+	case "web_fetch":
+		return "Web fetch"
+	case "write_file":
+		return "Write file"
+	case "edit_file":
+		return "Edit file"
+	case "multi_edit":
+		return "Multi-edit"
+	case "complete_step":
+		return "Mark step complete"
+	case "task":
+		return "Task"
+	default:
+		return name
+	}
+}
+
+func cmdTitle(verb string, p map[string]any) string {
+	c, _ := p["command"].(string)
+	c = strings.TrimSpace(c)
+	if c == "" {
+		return verb + " command"
+	}
+	if i := strings.IndexByte(c, '\n'); i >= 0 {
+		c = c[:i]
+	}
+	return verb + ": " + ellipsis(c, maxTitleArg)
+}
+
+func pathTitle(verb string, p map[string]any) string {
+	path, _ := p["path"].(string)
+	path = strings.TrimSpace(path)
+	if path == "" {
+		return verb
+	}
+	return verb + ": " + ellipsis(path, maxTitleArg)
+}
+
+func patternTitle(verb string, p map[string]any) string {
+	pat, _ := p["pattern"].(string)
+	pat = strings.TrimSpace(pat)
+	if pat == "" {
+		return verb
+	}
+	return verb + ": `" + ellipsis(pat, maxTitleArg-2) + "`"
+}
+
+func urlTitle(verb string, p map[string]any) string {
+	u, _ := p["url"].(string)
+	u = strings.TrimSpace(u)
+	if u == "" {
+		return verb
+	}
+	return verb + ": " + ellipsis(u, maxTitleArg)
+}
+
+func taskTitle(verb string, p map[string]any) string {
+	t, _ := p["description"].(string)
+	if t == "" {
+		t, _ = p["prompt"].(string)
+	}
+	t = strings.TrimSpace(t)
+	if t == "" {
+		return "Task"
+	}
+	return verb + ": " + ellipsis(t, maxTitleArg)
+}
+
+func ellipsis(s string, max int) string {
+	if len(s) <= max {
+		return s
+	}
+	return s[:max] + "…"
+}
+
+func plural(n int) string {
+	if n == 1 {
+		return ""
+	}
+	return "s"
+}
