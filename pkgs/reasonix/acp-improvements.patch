+// buildConfigOptions returns the current set of configurable session options:
+// the model picker (all configured provider/model refs) and the thinking toggle.
+func (s *service) buildConfigOptions(sess *acpSession) []SessionConfigOption {
+	modelRefs := s.factory.ModelRefs()
+	modelOpts := make([]SessionConfigOptionValue, 0, len(modelRefs))
+	currentLabel := sess.ctrl.Label()
+	for _, ref := range modelRefs {
+		modelOpts = append(modelOpts, SessionConfigOptionValue{
+			Value: ref,
+			Name:  ref,
+		})
+	}
+	currentModel := currentLabel
+	if currentModel == "" && len(modelRefs) > 0 {
+		currentModel = modelRefs[0]
+	}
+
+	// Strip planner suffix for the current model value.
+	modelName := currentModel
+	if idx := strings.Index(currentModel, " + planner "); idx >= 0 {
+		modelName = currentModel[:idx]
+	}
+
+	thinkingVal := "false"
+	if sess.thinking {
+		thinkingVal = "true"
+	}
