+func (s *service) modeSet(_ context.Context, raw json.RawMessage) (any, error) {
+	var p SetModeParams
+	if err := json.Unmarshal(raw, &p); err != nil {
+		return nil, &RPCError{Code: ErrInvalidParams, Message: "mode/set: " + err.Error()}
+	}
+	// If the mode ID matches a model ref, switch the session.
+	if p.ModeID != "" && p.SessionID != "" {
+		if sess := s.session(p.SessionID); sess != nil {
+			refs := s.factory.ModelRefs()
+			for _, ref := range refs {
+				if strings.EqualFold(ref, p.ModeID) {
+					// Found a matching model — rebuild the controller.
+					history := sess.ctrl.History()
+					newCtrl, err := s.factory.RebuildController(context.Background(), sess.params, ref, sess.thinking, history)
