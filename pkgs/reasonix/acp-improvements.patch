+// envMap accepts env as either a JSON object {"KEY":"VALUE"} or a JSON array of
+// "KEY=VALUE" strings (both forms appear in the wild — Claude Code and Zed use
+// different conventions) and normalises both into map[string]string.
+type envMap map[string]string
+
+func (e *envMap) UnmarshalJSON(b []byte) error {
+	var obj map[string]string
+	if err := json.Unmarshal(b, &obj); err == nil {
+		*e = envMap(obj)
+		return nil
+	}
+	var arr []string
+	if err := json.Unmarshal(b, &arr); err != nil {
+		return fmt.Errorf("env must be a JSON object or an array of KEY=VALUE strings")
+	}
+	m := make(envMap, len(arr))
+	for _, s := range arr {
+		k, v, ok := strings.Cut(s, "=")
+		if !ok {
+			return fmt.Errorf("env array element %q is not in KEY=VALUE format", s)
+		}
+		m[k] = v
+	}
+	*e = m
+	return nil
+}
